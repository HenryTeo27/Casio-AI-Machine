{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "style": "markdown",
    "compress": true
  },
  "include": [
    "AGENTS.md",
    "PROJECT_MAP.md",
    "agents/PROJECT_MAP.md",
    "agents/**/*.md",
    "skills/**/*.md",
    "platformio.ini",
    "src/**/*.c",
    "src/**/*.cpp",
    "src/**/*.h",
    "src/**/*.hpp",
    "include/**/*.h",
    "include/**/*.hpp",
    "lib/**/*.c",
    "lib/**/*.cpp",
    "lib/**/*.h",
    "lib/**/*.hpp",
    "test/**/*.c",
    "test/**/*.cpp",
    "test/**/*.h",
    "test/**/*.hpp",
    "server/README.md",
    "server/app/api/**/*.ts",
    "server/app/utils/casioFontconfig.ts",
    "server/prisma/**/*.sql",
    "server/prisma/**/*.prisma",
    "server/utils/prisma.ts"
  ],
  "ignore": {
    "useGitignore": true,
    "customPatterns": [
      ".git/**",
      ".pio/**",
      "build/**",
      ".vscode/**",
      "node_modules/**",
      ".next/**",
      "dist/**",
      "out/**",
      "coverage/**",
      ".cache/**",
      "tmp/**",
      "temp/**",
      "logs/**",
      "playwright-report/**",
      "test-results/**",
      "*.bin",
      "*.elf",
      "*.hex",
      "*.map",
      "*.o",
      "*.a",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.webp",
      "*.gif",
      "*.otf",
      "*.ttf",
      "*.woff",
      "*.woff2",
      "server/app/utils/fonts/**",
      "*.zip",
      "*.tar",
      "*.gz"
    ]
  }
}
