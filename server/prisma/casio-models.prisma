// Casio AI Machine Prisma model excerpt copied from EstateBoostCopilot/general/prisma/schema.prisma
// Add this excerpt into your own Prisma schema with matching datasource/generator settings.


model CasioAiQuestion {
    id               String         @id @default(uuid())
    deviceId         String
    questionNo       Int
    mode             String?
    modelHint        String?
    photoCount       Int            @default(0)
    status           String         @default("PENDING")
    contextTail      String?        @db.Text
    answer           String?        @db.Text
    displayText      String?        @db.Text
    displayBlocks    Json           @default("[]")
    errorMessage     String?        @db.Text
    promptTokens     Int?
    completionTokens Int?
    totalTokens      Int?
    completedAt      DateTime?
    createdAt        DateTime       @default(now())
    updatedAt        DateTime       @updatedAt
    photos           CasioAiPhoto[]

    @@unique([deviceId, questionNo])
    @@index([deviceId, createdAt])
    @@index([status, createdAt])
}

model CasioAiPhoto {
    id          String          @id @default(uuid())
    questionId  String
    question    CasioAiQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
    deviceId    String
    questionNo  Int
    photoIndex  Int
    blobUrl     String          @db.Text
    blobPath    String
    contentType String
    sizeBytes   Int
    sha256      String
    createdAt   DateTime        @default(now())
    updatedAt   DateTime        @updatedAt

    @@unique([deviceId, questionNo, photoIndex])
    @@index([questionId, photoIndex])
    @@index([deviceId, createdAt])
}
